# Atlas production env. Copy to .env.production and fill in.
# Do NOT commit .env.production — it's in .gitignore.

# ----------------------------------------------------------------------------
# SOURCE_DATABASE_URL — the operational LabStack DB.
# Read-only for Atlas. On a Linux VM with Postgres on the host, use
# host.docker.internal:5432 (the docker-compose extra_hosts mapping handles
# the Linux gateway routing automatically).
#
# Create a read-only role on the source DB:
#   CREATE ROLE atlas_reader LOGIN PASSWORD '<strong-pw>';
#   GRANT CONNECT ON DATABASE labstack TO atlas_reader;
#   GRANT USAGE ON SCHEMA public TO atlas_reader;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO atlas_reader;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO atlas_reader;
# ----------------------------------------------------------------------------
SOURCE_DATABASE_URL=postgresql://atlas_reader:CHANGEME@host.docker.internal:5432/labstack

# ----------------------------------------------------------------------------
# APP_DATABASE_URL — Atlas's own DB, hosted by the atlas-db service in this
# docker-compose stack.
# Default works out of the box; only set this explicitly if you want
# atlas-web to point at a managed Postgres instead.
# ----------------------------------------------------------------------------
# APP_DATABASE_URL=postgres://atlas:atlas@atlas-db:5432/atlas

# ----------------------------------------------------------------------------
# ATLAS_DB_PASSWORD — Postgres password for the atlas-db container.
# Used by both the Postgres init and the default APP_DATABASE_URL above.
# Change before exposing the host's 5433 port to anything you don't trust.
# ----------------------------------------------------------------------------
ATLAS_DB_PASSWORD=atlas

# ----------------------------------------------------------------------------
# APP_URL — public origin Atlas is served at. Used for absolute redirect URLs
# (e.g. on logout). Include scheme; no trailing slash.
# ----------------------------------------------------------------------------
APP_URL=https://atlas.your-domain.example
